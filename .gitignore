htmlcov/

# Notebook checkpoints
.ipynb_checkpoints/

# Local environments and secrets
.venv/
venv/
.env
.env.*
*.pem
*.key

# Downloaded archives and platform files
*.zip
*.tar
*.tar.gz
*.7z
.DS_Store
